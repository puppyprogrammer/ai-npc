{
  "name": "ai-npc-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Drop-in conversational 3D AI NPC for the web (Three.js). Monorepo root.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:demo": "npm run dev --workspace apps/demo"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
